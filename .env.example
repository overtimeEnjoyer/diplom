NODE_ENV=development
PORT=3000

# PostgreSQL — нова порожня БД для API (окрема від старої CMS-БД)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/rok_m_new

# Лише для копіювання зі старої PostgreSQL (не комітити):
# LEGACY_DATABASE_URL=postgresql://user:pass@old-host:5432/rok_m_dev
# На Neon/Supabase SSL визначається автоматично з URL; або явно:
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=5
DATABASE_READ_REPLICA_URL=

# Optional read replica (comma-separated URLs)
# DATABASE_READ_REPLICA_URL=postgresql://...

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://rok-mentalhealth.com,https://www.rok-mentalhealth.com

# Email (password reset fallback)
EMAIL_FROM=no-reply@example.com
SENDGRID_API_KEY=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

# Brevo (preferred for password reset)
BREVO_API_KEY=
BREVO_TEMPLATE_PASSWORD_RESET=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=ROK Mental Health

# WayForPay
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_MERCHANT_DOMAIN_NAME=
WAYFORPAY_MERCHANT_SECRET_KEY=
WAYFORPAY_MERCHANT_PASSWORD=
WAYFORPAY_RETURN_URL=https://rok-mentalhealth.com
WAYFORPAY_SERVICE_URL=https://your-api.vercel.app/api/payments/wayforpay-callback
WAYFORPAY_DEBUG_LOGS=false

SEQUELIZE_LOGGING=false

# Admin user (seed 20260526100002-admin-user)
ADMIN_EMAIL=admin@rok-mentalhealth.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!ChangeMe
