NODE_ENV=development
PORT=3000

# PostgreSQL — нова порожня БД для API (окрема від старої CMS-БД)
# Локально з Docker (docker-compose.yml) — за замовчуванням:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/rok_m_dev

# Лише для копіювання зі старої PostgreSQL (не комітити):
# LEGACY_DATABASE_URL=postgresql://user:pass@old-host:5432/rok_m_dev
# На Neon/Supabase SSL визначається автоматично з URL; або явно:
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=5
DATABASE_READ_REPLICA_URL=

# Optional read replica (comma-separated URLs)
# DATABASE_READ_REPLICA_URL=postgresql://...

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://rok-mentalhealth.com,https://www.rok-mentalhealth.com

# Email (password reset fallback)
EMAIL_FROM=no-reply@example.com
SENDGRID_API_KEY=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

# Brevo (preferred for password reset)
BREVO_API_KEY=
BREVO_TEMPLATE_PASSWORD_RESET=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=ROK Mental Health

# Payments (provider-agnostic — mock in dev, manual in production)
PAYMENT_PROVIDER=mock
# Allow POST /api/payments/confirm in production (demo only)
# PAYMENT_MOCK_CONFIRM=true

# WayForPay webhook (thesis §3.3)
# WAYFORPAY_MERCHANT_SECRET=

# Supabase Auth + Storage (thesis §2.6, §3.4) — optional BaaS delegation
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_JWT_SECRET=your-project-jwt-secret
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=media

# Presigned uploads: supabase | s3
UPLOAD_PROVIDER=supabase
# AWS_S3_BUCKET=
# AWS_S3_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Catalog edge cache TTL (in-memory per serverless instance)
CONTENT_CACHE_TTL_MS=60000

# Auth rate limiting
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=30
MFA_TOKEN_EXPIRES_IN=10m

SEQUELIZE_LOGGING=false

# --- Load test / Vercel metrics (локально або проти Preview URL) ---
# LOAD_BASE_URL=https://your-app.vercel.app
# LOAD_DURATION_SEC=180
# LOAD_CONNECTIONS=50
# LOAD_BURST_CONNECTIONS=100
# LOAD_IDLE_SEC=600
# ENABLE_LOAD_TEST_ROUTES=true
# LOAD_USER_EMAIL=test@example.com
# LOAD_USER_PASSWORD=password123

# Admin user (seed 20260526100002-admin-user)
ADMIN_EMAIL=admin@rok-mentalhealth.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!ChangeMe
