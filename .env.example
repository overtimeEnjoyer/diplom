# Copy to .env and fill in values: cp .env.example .env

# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (required in production) ---
# Local Docker: postgresql://postgres:postgres@127.0.0.1:5432/rok_m_dev
# Neon/Supabase: paste connection string (SSL is auto-detected)
DATABASE_URL=

# Optional
# DATABASE_READ_REPLICA_URL=
# LEGACY_DATABASE_URL=

# --- Auth (required in production: strong random JWT_SECRET) ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
MFA_TOKEN_EXPIRES_IN=10m

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://rok-mentalhealth.com,https://www.rok-mentalhealth.com

# --- Email / password reset (optional) ---
EMAIL_FROM=no-reply@example.com
BREVO_API_KEY=
BREVO_TEMPLATE_PASSWORD_RESET=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=ROK Mental Health
SENDGRID_API_KEY=

# --- Payments ---
PAYMENT_PROVIDER=mock
# PAYMENT_MOCK_CONFIRM=true
# WAYFORPAY_MERCHANT_SECRET=

# --- Supabase (optional; without SUPABASE_JWT_SECRET — local login only) ---
# SUPABASE_URL=
# SUPABASE_JWT_SECRET=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=media

# --- File uploads (supabase | s3) ---
UPLOAD_PROVIDER=supabase
# AWS_S3_BUCKET=
# AWS_S3_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Cache & performance (optional) ---
# REDIS_URL=redis://127.0.0.1:6379
CONTENT_CACHE_TTL_MS=60000
EXTERNAL_FETCH_TIMEOUT_MS=15000

# --- Dev / ops ---
SEQUELIZE_LOGGING=false
# ENABLE_LOAD_TEST_ROUTES=true

# --- Admin user (pnpm db:seed) ---
ADMIN_EMAIL=admin@rok-mentalhealth.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!ChangeMe
