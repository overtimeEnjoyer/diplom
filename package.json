{
  "name": "rok-m-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.14.2",
  "description": "Serverless REST API for educational materials platform (Express + Sequelize + PostgreSQL)",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --runInBand --forceExit",
    "test:watch": "pnpm test -- --watch",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:seed": "sequelize-cli db:seed:all",
    "db:reset": "sequelize-cli db:migrate:undo:all && sequelize-cli db:migrate && sequelize-cli db:seed:all",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "import:methodics": "tsx scripts/import-methodics.ts",
    "migrate:legacy-db": "tsx scripts/migrate-legacy-db.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "start:here": "bash scripts/first-run.sh",
    "setup:local": "bash scripts/setup-local.sh",
    "db:prepare-new": "bash scripts/prepare-new-db.sh",
    "load:auth": "node tests/load/auth-load.js",
    "load:content": "node tests/load/content-load.js",
    "load:payments": "node tests/load/payments-load.js",
    "load:progress": "node tests/load/progress-load.js",
    "load:peak": "node tests/load/peak-load.js",
    "load:vercel-metrics": "node tests/load/vercel-metrics.js",
    "load:vercel-metrics:gentle": "LOAD_BASE_URL=https://rok-m-backend.vercel.app LOAD_GENTLE=true node tests/load/vercel-metrics.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.5",
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "autocannon": "^8.0.0",
    "jest": "^29.7.0",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.0.0",
    "tsx": "^4.22.3"
  },
  "engines": {
    "node": ">=18.0.0 <=23.x.x"
  }
}
